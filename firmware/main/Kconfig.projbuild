menu "APP Configuration"

    config PULSEMETER_RESTART_COUNT_RESET
        int "Restart count threshold for settings reset"
        range 3 10
        default 5
        help
            Erase NVS and restart once the persisted restart counter reaches
            this threshold.

    config PULSEMETER_WIFI_AP_SSID
        string "Provisioning Wi-Fi AP SSID"
        default "PulseMeter"
        help
            SSID used by the temporary SoftAP during Wi-Fi provisioning.

endmenu
